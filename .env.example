# ──────────────────────────────────────────
# Telegram
# ──────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Comma-separated list of Telegram user IDs allowed to use the bot
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# ──────────────────────────────────────────
# Anthropic (DeepAgent)
# ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model to use – defaults to claude-opus-4-6
CLAUDE_MODEL=claude-opus-4-6
# Extended-thinking token budget (0 to disable)
THINKING_BUDGET=8000

# ──────────────────────────────────────────
# Google (Gmail + Drive + YouTube)
# Run `python get_google_token.py` to generate these.
# ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
# YouTube Data API key (server-key, not OAuth – for public search)
YOUTUBE_API_KEY=your_youtube_api_key

# ──────────────────────────────────────────
# Slack
# ──────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
# Default workspace domain (optional, used for display)
SLACK_WORKSPACE=your-workspace.slack.com

# ──────────────────────────────────────────
# Twitter / X
# ──────────────────────────────────────────
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# ──────────────────────────────────────────
# GitHub
# ──────────────────────────────────────────
GITHUB_TOKEN=ghp_...
# Default GitHub username (used when owner is omitted)
GITHUB_USERNAME=your_github_username

# ──────────────────────────────────────────
# Browser
# ──────────────────────────────────────────
BROWSER_HEADLESS=true
